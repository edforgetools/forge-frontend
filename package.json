{
  "name": "forge-frontend",
  "private": true,
  "dependencies": {
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/mdx": "^2.0.13",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.468.0",
    "multer": "^2.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "tailwind-merge": "^2.5.4",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "autoprefixer": "^10.4.21",
    "bundlesize": "^0.18.2",
    "postcss": "^8.5.6",
    "rollup-plugin-visualizer": "^5.12.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.5.4",
    "vite": "^7.1.7",
    "vitest": "^1.6.0"
  },
  "scripts": {
    "dev": "node -e \"const apiBase = process.env.VITE_API_BASE || 'http://localhost:8787'; console.log('\\n🚀 Starting Forge Frontend...'); console.log('📡 API Base URL:', apiBase); console.log('\\n');\" && vite",
    "build": "tsc -b && vite build",
    "build:prod": "tsc -b && vite build --mode production",
    "build:vercel": "tsc -b && vite build --mode production",
    "build:analyze": "tsc -b && vite build --mode production && npx bundlesize",
    "bundlesize": "bundlesize",
    "preview": "vite preview",
    "test": "vitest",
    "type-check": "tsc --noEmit"
  },
  "bundlesize": [
    {
      "path": "./dist/assets/*.js",
      "maxSize": "250kb",
      "compression": "gzip"
    }
  ]
}
